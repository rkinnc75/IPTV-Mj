<?xml version="1.0" encoding="utf-8"?>
<!-- Scoped to exactly the APK update directory the FileProvider needs
     (getExternalFilesDir(DIRECTORY_DOWNLOADS) -> files/Download/). The previous
     "." roots exposed the entire cache/files trees to any granted recipient. -->
<paths>
    <external-files-path name="apk_downloads" path="Download/" />
</paths>
